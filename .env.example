# AccidentAI Configuration Template
# Copy this file to '.env' and fill in your values.

# Model parameters
MODEL_PATH=model.h5
IMG_HEIGHT=48
IMG_WIDTH=48
FRAME_SKIP=30
MAX_FRAMES=75

# MongoDB config (Optional)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=accident_ai
MONGO_COL=incidents

# Email Alert configurations (Optional)
EMAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_TO=recipient-email@gmail.com

# Twilio SMS Alert configurations (Optional)
SMS_ENABLED=False
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
TWILIO_TO=+91XXXXXXXXXX

# Live camera configuration (0 for webcam, rtsp:// link for CCTV)
CAMERA_SOURCE=0
